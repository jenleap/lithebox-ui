{
  "name": "lithebox-ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "sideEffects": [
    "./src/metadata/components/layoutMetadata.ts",
    "./src/metadata/components/primitiveMetadata.ts",
    "./src/metadata/components/formMetadata.ts",
    "./src/metadata/components/navigationMetadata.ts",
    "./src/metadata/components/dataDisplayMetadata.ts",
    "./src/metadata/components/feedbackMetadata.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^14",
    "@types/node": "^25.9.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "@vitest/ui": "^1",
    "jsdom": "^24",
    "react": "^18",
    "react-dom": "^18",
    "storybook": "^8.6.18",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^1"
  }
}
